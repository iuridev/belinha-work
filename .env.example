# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env NUNCA deve ser commitado no GitHub.

# ── Flask ───────────────────────────────────────────────────────────────────
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=substitua-por-uma-chave-aleatoria-longa

# ── Google Sheets ────────────────────────────────────────────────────────────
# ID da sua planilha (parte da URL: /spreadsheets/d/ESTE_ID/edit)
SPREADSHEET_ID=cole-aqui-o-id-da-planilha

# ── Credenciais da conta de serviço (para produção / Vercel) ─────────────────
# Para uso LOCAL: mantenha o arquivo credentials.json na raiz do projeto.
# Para PRODUÇÃO (Vercel): cole aqui o conteúdo COMPLETO do credentials.json
# em uma única linha (use: python -c "import json,sys; print(json.dumps(json.load(open('credentials.json'))))")
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
